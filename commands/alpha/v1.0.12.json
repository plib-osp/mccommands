        "/kick Player1 Breaking rules"
      ]
    },
    {
      "name": "op",
      "description": "Grants operator status to a player, allowing use of all commands.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/op <player>",
          "params": {
            "player": "Player to grant operator"
          }
        }
      ],
      "examples": [
