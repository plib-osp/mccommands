        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/deop <player>",
          "params": {
            "player": "Player to remove operator from"
          }
        }
      ],
      "examples": [
        "/deop Notch"
      ]
    },
    {
      "name": "kick",
      "description": "Kicks a player from the server with an optional reason.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
