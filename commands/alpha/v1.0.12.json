      ]
    },
    {
      "name": "say",
      "description": "Sends a message to all players in chat via the server.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 2,
      "multiplayer_only": false,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/say <message>",
          "params": {
            "message": "Message text to broadcast"
          }
        }
      ],
      "examples": [
        "/say Hello everyone!",
        "/say Server will restart in 5 minutes"
      ]
    },
    {
      "name": "tell",
      "description": "Sends a private message to a specific player.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 0,
      "multiplayer_only": false,
      "aliases": [
        "msg",
        "w"
      ],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/tell <player> <message>",
          "params": {
            "player": "Target player",
            "message": "Private message"
          }
        }
      ],
      "examples": [
        "/tell Notch Hello",
        "/msg Player1 hi"
      ]
    },
    {
      "name": "whitelist",
      "description": "Manages the server whitelist for joining players.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/whitelist <add|remove|list|on|off> [player]",
          "params": {
            "action": "add, remove, list, on, or off",
            "player": "Player to add/remove"
          }
        }
      ],
      "examples": [
        "/whitelist add Player1",
        "/whitelist on",
        "/whitelist list"
      ]
    }
  ]
