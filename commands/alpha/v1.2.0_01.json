      "description": "Gives an item to a player. The most commonly used command for spawning items.",
      "introduced": "Alpha v1.0.16",
      "removed": null,
      "permission_level": 2,
      "multiplayer_only": false,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.16 - 1.5",
          "pattern": "/give <player> <id> [count] [data]",
          "params": {
            "player": "Target player",
            "id": "Numeric item ID",
            "count": "Number of items (default 1)",
            "data": "Damage value (default 0)"
          }
        },
        {
          "version_range": "Release 1.6+",
          "pattern": "/give <player> <item> [count] [data] [nbt]",
          "params": {
            "player": "Target",
            "item": "Item name or ID",
            "count": "Amount",
            "data": "Damage value",
            "nbt": "NBT compound tag"
          }
        },
        {
          "version_range": "Release 1.13+",
          "pattern": "/give <targets> <item> [count]",
          "params": {
            "targets": "Target selector",
            "item": "Namespaced item ID",
            "count": "Number of items"
          }
        }
      ],
      "examples": [
        "/give Player1 diamond",
        "/give @p minecraft:diamond_sword 1",
        "/give @a minecraft:arrow 64"
      ],
