{
  "version": "Beta b1.0",
  "type": "beta",
  "commands": [
    {
      "name": "ban",
      "description": "Adds a player to the server banlist, preventing them from joining.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/ban <player> [reason]",
          "params": {
            "player": "Player name to ban",
            "reason": "Optional ban reason"
          }
        }
      ],
      "examples": [
        "/ban Notch",
        "/ban Player1 Breaking rules"
      ],
      "gamerules": []
    },
    {
      "name": "ban-ip",
      "description": "Adds an IP address to the server banlist.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/ban-ip <ip>",
          "params": {
            "ip": "IP address to ban"
          }
        }
      ],
      "examples": [
        "/ban-ip 192.168.1.1"
      ]
    },
    {
      "name": "banlist",
      "description": "Displays the server banlist.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/banlist [ips|players]",
          "params": {
            "ips": "List banned IPs",
            "players": "List banned players"
          }
        }
      ],
      "examples": [
        "/banlist",
        "/banlist ips"
      ]
    },
    {
      "name": "deop",
      "description": "Removes operator status from a player.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/deop <player>",
          "params": {
            "player": "Player to remove operator from"
          }
        }
      ],
      "examples": [
        "/deop Notch"
      ]
    },
    {
      "name": "kick",
      "description": "Kicks a player from the server with an optional reason.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/kick <player> [reason]",
          "params": {
            "player": "Player to kick",
            "reason": "Optional kick reason"
          }
        }
      ],
      "examples": [
        "/kick Player1",
        "/kick Player1 Breaking rules"
      ]
    },
    {
      "name": "op",
      "description": "Grants operator status to a player, allowing use of all commands.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/op <player>",
          "params": {
            "player": "Player to grant operator"
          }
        }
      ],
      "examples": [
        "/op Notch"
      ]
    },
    {
      "name": "pardon",
      "description": "Removes a player from the server banlist.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/pardon <player>",
          "params": {
            "player": "Player to unban"
          }
        }
      ],
      "examples": [
        "/pardon Notch"
      ]
    },
    {
      "name": "say",
      "description": "Sends a message to all players in chat via the server.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 2,
      "multiplayer_only": false,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/say <message>",
          "params": {
            "message": "Message text to broadcast"
          }
        }
      ],
      "examples": [
        "/say Hello everyone!",
        "/say Server will restart in 5 minutes"
      ]
    },
    {
      "name": "tell",
      "description": "Sends a private message to a specific player.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 0,
      "multiplayer_only": false,
      "aliases": [
        "msg",
        "w"
      ],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/tell <player> <message>",
          "params": {
            "player": "Target player",
            "message": "Private message"
          }
        }
      ],
      "examples": [
        "/tell Notch Hello",
        "/msg Player1 hi"
      ]
    },
    {
      "name": "whitelist",
      "description": "Manages the server whitelist for joining players.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/whitelist <add|remove|list|on|off> [player]",
          "params": {
            "action": "add, remove, list, on, or off",
            "player": "Player to add/remove"
          }
        }
      ],
      "examples": [
        "/whitelist add Player1",
        "/whitelist on",
        "/whitelist list"
      ]
    },
    {
      "name": "give",
      "description": "Gives an item to a player. The most commonly used command for spawning items.",
      "introduced": "Alpha v1.0.16",
      "removed": null,
      "permission_level": 2,
      "multiplayer_only": false,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.16 - 1.5",
          "pattern": "/give <player> <id> [count] [data]",
          "params": {
            "player": "Target player",
            "id": "Numeric item ID",
            "count": "Number of items (default 1)",
            "data": "Damage value (default 0)"
          }
        },
        {
          "version_range": "Release 1.6+",
          "pattern": "/give <player> <item> [count] [data] [nbt]",
          "params": {
            "player": "Target",
            "item": "Item name or ID",
            "count": "Amount",
            "data": "Damage value",
            "nbt": "NBT compound tag"
          }
        },
        {
          "version_range": "Release 1.13+",
          "pattern": "/give <targets> <item> [count]",
          "params": {
            "targets": "Target selector",
            "item": "Namespaced item ID",
            "count": "Number of items"
          }
        }
      ],
      "examples": [
        "/give Player1 diamond",
        "/give @p minecraft:diamond_sword 1",
        "/give @a minecraft:arrow 64"
      ],
      "gamerules": []
    },
    {
      "name": "kill",
      "description": "Kills entities. In Alpha/Beta it killed the executor with 1000 damage. From 1.13+ can target any entity.",
      "introduced": "Alpha v1.2.6",
      "removed": null,
      "permission_level": 2,
      "multiplayer_only": false,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.2.6 - 1.12",
          "pattern": "/kill",
          "params": {},
          "description_extra": "Kills the executor"
        },
        {
          "version_range": "Release 1.13+",
          "pattern": "/kill [targets]",
          "params": {
            "targets": "Entities to kill (defaults to executor)"
          }
        }
      ],
      "examples": [
        "/kill",
        "/kill @e[type=!player]"
      ],
      "gamerules": []
    },
    {
      "name": "gamemode",
      "description": "Sets a player's game mode (survival, creative, adventure, or spectator).",
      "introduced": "Beta 1.0",
      "removed": null,
      "permission_level": 2,
      "multiplayer_only": false,
      "aliases": [
        "gm"
      ],
      "syntax": [
        {
          "version_range": "Beta 1.0 - 1.12",
          "pattern": "/gamemode <mode> [player]",
          "params": {
            "mode": "survival/creative/adventure or 0/1/2",
            "player": "Target player (default self)"
          }
        },
        {
          "version_range": "Release 1.13+",
          "pattern": "/gamemode <gamemode> [targets]",
          "params": {
            "gamemode": "survival/creative/adventure/spectator",
            "targets": "Target selector"
          }
        }
      ],
      "examples": [
        "/gamemode creative",
        "/gamemode survival Player1",
        "/gamemode 1 @a"
      ]
    },
    {
      "name": "pardon-ip",
      "description": "Removes an IP address from the server banlist.",
      "introduced": "Beta 1.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Beta 1.0+",
          "pattern": "/pardon-ip <ip>",
          "params": {
            "ip": "IP address to unban"
          }
        }
      ],
      "examples": [
        "/pardon-ip 192.168.1.1"
      ]
    }
  ],
  "notes": "First Beta version. Game mode command added. Price increased."
}