      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/ban-ip <ip>",
          "params": {
            "ip": "IP address to ban"
          }
        }
      ],
      "examples": [
        "/ban-ip 192.168.1.1"
      ]
    },
