          "pattern": "/kill",
          "params": {},
          "description_extra": "Kills the executor"
        },
        {
          "version_range": "Release 1.13+",
          "pattern": "/kill [targets]",
          "params": {
            "targets": "Entities to kill (defaults to executor)"
          }
        }
