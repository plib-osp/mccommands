  "commands": [
    {
      "name": "ban",
      "description": "Adds a player to the server banlist, preventing them from joining.",
      "introduced": "Alpha v1.0.0",
      "removed": null,
      "permission_level": 3,
      "multiplayer_only": true,
      "aliases": [],
      "syntax": [
        {
          "version_range": "Alpha v1.0.0+",
          "pattern": "/ban <player> [reason]",
          "params": {
            "player": "Player name to ban",
            "reason": "Optional ban reason"
          }
        }
      ],
      "examples": [
        "/ban Notch",
        "/ban Player1 Breaking rules"
      ],
      "gamerules": []
    },
    {
      "name": "ban-ip",
      "description": "Adds an IP address to the server banlist.",
